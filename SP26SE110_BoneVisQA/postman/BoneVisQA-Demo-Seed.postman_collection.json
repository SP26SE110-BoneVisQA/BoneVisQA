          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const targetName = pm.environment.get('seedClassName');",
              "const maybe = pm.response.json();",
              "const id = maybe?.id || maybe?.result?.id || maybe?.Result?.id;",
              "if (id) pm.environment.set('seedClassId', id);",
