  "item": [
    {
      "name": "00 - Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/DbHealth/check",
          "host": ["{{baseUrl}}"],
          "path": ["api", "DbHealth", "check"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Health endpoint is reachable', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "01 - Admin Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auths/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auths", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const res = pm.response.json();",
              "pm.test('Admin login succeeds', function () {",
              "  pm.expect(pm.response.code).to.eql(200);",
              "  pm.expect(res.success).to.eql(true);",
              "  pm.expect(res.token).to.be.a('string');",
              "});",
              "pm.environment.set('adminToken', res.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Ensure Demo Student User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{seedStudentEmail}}\",\n  \"fullName\": \"Demo Student 21Apr\",\n  \"password\": \"{{seedStudentPassword}}\",\n  \"schoolCohort\": \"SE110-SP26\",\n  \"role\": \"Student\",\n  \"sendWelcomeEmail\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/users",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const email = pm.environment.get('seedStudentEmail');",
              "function saveUserIdFromList(items, envKey) {",
              "  const user = (items || []).find(u => String(u.email || '').toLowerCase() === String(email).toLowerCase());",
              "  if (user && user.id) pm.environment.set(envKey, user.id);",
              "}",
              "if (pm.response.code === 201 || pm.response.code === 200) {",
              "  const created = pm.response.json();",
              "  const id = created?.result?.id || created?.Result?.id || created?.id;",
              "  if (id) pm.environment.set('seedStudentId', id);",
              "}",
              "pm.sendRequest({",
              "  url: pm.environment.get('baseUrl') + '/api/admin/users?page=1&pageSize=200',",
              "  method: 'GET',",
              "  header: { Authorization: 'Bearer ' + pm.environment.get('adminToken') }",
              "}, function (err, resp) {",
              "  if (err || !resp) return;",
              "  const body = resp.json();",
              "  saveUserIdFromList(body.items || body.result || body.Result || [], 'seedStudentId');",
              "});",
              "pm.test('Student ensure request accepted', function () {",
              "  pm.expect([200, 201, 400, 409]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02b - Optional Upload Demo PDF (fills documents/document_chunks)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "Title", "value": "Demo Bone Oncology Reference", "type": "text" },
            { "key": "File", "type": "file", "src": "{{seedPdfPath}}" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/documents/upload",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "documents", "upload"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Document upload request accepted or intentionally skipped', function () {",
              "  pm.expect([200, 201, 400, 404]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ]
    },
