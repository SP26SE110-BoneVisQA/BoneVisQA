    {
      "name": "09 - Seed Case + Legacy Question + Visual QA",
      "item": [
        {
          "name": "Create Expert Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{expertToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Demo Case - Osteolytic Lesion 21Apr\",\n  \"description\": \"Demo case for lecturer-expert review workflow.\",\n  \"difficulty\": \"Intermediate\",\n  \"suggestedDiagnosis\": \"Osteosarcoma\",\n  \"keyFindings\": \"Aggressive periosteal reaction and mixed lytic-sclerotic pattern.\",\n  \"medicalImages\": [\n    {\n      \"imageUrl\": \"{{seedCaseImagePublicUrl}}\",\n      \"modality\": \"X-Ray\",\n      \"annotations\": [\n        {\n          \"label\": \"suspected-lesion\",\n          \"coordinates\": \"{\\\"x\\\":0.33,\\\"y\\\":0.21,\\\"width\\\":0.24,\\\"height\\\":0.27}\"\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/expert/cases", "host": ["{{baseUrl}}"], "path": ["api", "expert", "cases"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "const caseId = r?.id || r?.result?.id || r?.Result?.id;",
                  "if (caseId) pm.environment.set('seedCaseId', caseId);",
                  "const img = (r?.medicalImages || r?.result?.medicalImages || [])[0];",
                  "if (img && img.id) pm.environment.set('seedImageId', img.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Legacy Student Question (fills student_questions)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"caseId\": \"{{seedCaseId}}\",\n  \"questionText\": \"Legacy flow question for dashboard compatibility.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/student/questions", "host": ["{{baseUrl}}"], "path": ["api", "student", "questions"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  const id = r?.id || r?.result?.id || r?.Result?.id;",
                  "  if (id) pm.environment.set('seedLegacyQuestionId', id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Ask Visual QA (ask-json)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionText\": \"{{seedQuestionText}}\",\n  \"imageUrl\": \"{{seedCaseImagePublicUrl}}\",\n  \"caseId\": \"{{seedCaseId}}\",\n  \"imageId\": \"{{seedImageId}}\",\n  \"coordinates\": \"{\\\"x\\\":0.34,\\\"y\\\":0.22,\\\"width\\\":0.21,\\\"height\\\":0.23}\",\n  \"clientRequestId\": \"seed-{{$timestamp}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/student/visual-qa/ask-json", "host": ["{{baseUrl}}"], "path": ["api", "student", "visual-qa", "ask-json"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "const sid = r?.sessionId || r?.latestTurn?.sessionId;",
                  "const tid = r?.latestTurn?.turnId || r?.turnId;",
                  "if (sid) pm.environment.set('seedSessionId', sid);",
                  "if (tid) pm.environment.set('seedTurnId', tid);"
                ]
              }
            }
          ]
        },
        {
          "name": "Request Lecturer Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{studentToken}}" }
            ],
            "url": {
